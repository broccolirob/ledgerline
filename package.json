{
  "name": "ledgerline",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @ledgerline/demo-seller-express dev",
    "dev:buyer": "pnpm --filter @ledgerline/demo-buyer start",
    "deposit": "pnpm --filter @ledgerline/demo-buyer deposit",
    "typecheck": "pnpm -r typecheck",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:wait": "until docker exec ledgerline-pg psql -U ledgerline -d ledgerline -c 'select 1' >/dev/null 2>&1; do echo 'waiting for postgres...'; sleep 1; done; echo 'postgres ready'",
    "db:migrate": "pnpm run db:wait && pnpm --filter @ledgerline/db migrate",
    "recognize": "pnpm --filter @ledgerline/recognition recognize",
    "export:csv": "pnpm --filter @ledgerline/recognition export:csv",
    "audit:balance": "pnpm --filter @ledgerline/recognition run audit",
    "anchor:build": "pnpm --filter @ledgerline/anchor run build-batch",
    "anchor:submit": "pnpm --filter @ledgerline/anchor run submit",
    "verify": "pnpm --filter @ledgerline/anchor run verify",
    "vectors:check": "pnpm --filter @ledgerline/anchor run vectors:check",
    "contracts:test": "cd contracts && forge test --match-contract RevenueBatchAnchorTest",
    "demo": "pnpm --filter @ledgerline/anchor run demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run .security.test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
