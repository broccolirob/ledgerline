# .env.example — copy to .env  (.env is gitignored)
#
# Track B runs locally with NO credentials. Vars marked (Track A) are only needed for the
# live 402 -> pay -> 200 loop and are filled when Track A lands. The tsx-launched dev/start
# scripts load this file via Node's --env-file-if-exists flag (no dotenv dependency).

# ============================================================================
# NEEDED NOW — credential-free local run
# ============================================================================
# Host port 5433 avoids clashing with a native/Homebrew Postgres on 5432.
DATABASE_URL=postgresql://ledgerline:ledgerline@localhost:5433/ledgerline
ARC_CHAIN_ID=5042002
# Verified default is also baked into the seller code; only consumed once the paid route
# mounts (i.e. alongside SELLER_ADDRESS). Verify against current Circle docs.
FACILITATOR_URL=https://gateway-api-testnet.circle.com

# ============================================================================
# NEEDED WHEN TRACK A LANDS — the live payment loop
# ============================================================================
SELLER_ADDRESS=            # Arc Testnet seller EOA receive address; also gates the paid route mounting
BUYER_PRIVATE_KEY=         # TESTNET ONLY — demo-buyer EOA signing key
ARC_RPC_URL=               # Arc Testnet RPC (one-time deposit / direct reads); verify the URL
SELLER_URL=http://localhost:4021/api/company-brief

# CIRCLE_API_KEY appears in the plan but is likely NOT needed for the Nanopayments x402 loop
# (auth is by wallet signature) — verify in the Circle console before treating absence as a blocker.
CIRCLE_API_KEY=

# Optional — tenant the raw_events are written under. Defaults in code to the demo tenant
# (00000000-0000-4000-8000-000000000001) seeded by migration 0002. Override only for a real tenant.
LEDGERLINE_TENANT_ID=

# ============================================================================
# M6b — adapter-event signing (optional; closes T6 in the local pipeline).
# Run `pnpm adapter:keygen` to register a key and obtain both values. When set, the demo seller signs
# captured events; recognition only ENFORCES signatures when requireAdapterSignature is enabled.
# ADAPTER_SIGNING_KEY is a multi-line Ed25519 PKCS#8 PEM — quote it (Node --env-file supports
# multi-line quoted values). LOCAL/TESTNET only; never commit a real private key.
# ============================================================================
ADAPTER_KEY_ID=            # key id printed by `pnpm adapter:keygen`
ADAPTER_SIGNING_KEY=       # Ed25519 private-key PEM printed by keygen (quoted, multi-line)

# ============================================================================
# M6c — official x402 Signed Offer/Receipt issuance (Path B; optional).
# When set, the demo seller ALSO issues + captures the official EIP-712 signed offer/receipt alongside
# the Path-C analog (verifier steps 1-3 then re-verify the real artifact). RECEIPT_SIGNING_KEY is a
# DEDICATED secp256k1 EOA private key, DISTINCT from SELLER_ADDRESS/payTo (the demo THROWS at boot if
# they match) — it only SIGNS offers/receipts, never settles. LOCAL/TESTNET only; never commit a real key.
# Generate one with `generateReceiptSigningKey()` from @ledgerline/x402-receipts.
# ============================================================================
RECEIPT_SIGNING_KEY=       # 0x-prefixed secp256k1 private key; enables Path B issuance. NOT the seller key.
USDC_CONTRACT=             # optional — token contract address used as the offer `asset` (defaults to Arc Testnet USDC).

# ============================================================================
# M4 — Arc commitment anchor (Track A; live on-chain only). The canonical/Merkle/verifier core,
# `pnpm anchor:build`, `pnpm verify` (offline), and `pnpm contracts:test` all run WITHOUT these.
# Needed only for `pnpm anchor:submit` and `pnpm verify --onchain`. Deploy first:
#   cd contracts && forge script script/Deploy.s.sol --broadcast --rpc-url $ARC_RPC_URL
# (reuses ARC_RPC_URL above).
# ============================================================================
ANCHOR_COMMITTER_KEY=      # TESTNET ONLY — deployer/committer EOA key (granted COMMITTER_ROLE). USDC is gas on Arc.
ANCHOR_CONTRACT_ADDRESS=   # RevenueBatchAnchor address, filled in after deploy.
